{
  "name": "marketplace-alert-backend",
  "version": "1.0.0",
  "description": "Real-time marketplace alert backend (Facebook Marketplace, OfferUp, eBay) with dedup, REST API, and FCM push.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch-path=src src/index.js",
    "postinstall": "playwright install chromium",
    "test:ebay": "node scripts/test-ebay.js",
    "test:offerup": "node scripts/test-offerup.js",
    "test:facebook": "node scripts/test-facebook.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fingerprint-generator": "^2.1.82",
    "fingerprint-injector": "^2.1.82",
    "firebase-admin": "^12.5.0",
    "ghost-cursor": "^1.4.2",
    "playwright": "^1.47.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rss-parser": "^3.13.0"
  }
}
