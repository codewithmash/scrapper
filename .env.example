# ---- Server ----
PORT=3000
API_KEY=change-me-to-a-long-random-string   # required in x-api-key header to call the REST endpoints

# ---- Polling intervals (seconds) ----
EBAY_POLL_SECONDS=60
OFFERUP_POLL_SECONDS=150
FACEBOOK_POLL_SECONDS=210

# ---- Search targets (JSON array) ----
# Each object is a unique search that gets polled and fanned out to subscribers by your dashboard.
# platform: "ebay" | "offerup" | "facebook"
# See README for field meanings.
SEARCHES='[
  { "platform": "ebay",     "keyword": "iphone 15", "location": "US",      "minPrice": 0, "maxPrice": 800 },
  { "platform": "offerup",  "keyword": "dyson",     "location": "toronto", "minPrice": 0, "maxPrice": 400 },
  { "platform": "facebook", "keyword": "bike",      "location": "toronto", "minPrice": 0, "maxPrice": 500 }
]'

# ---- Facebook ----
# Directory containing one or more cookie JSON files exported from warmed accounts (Playwright storageState format).
FB_COOKIES_DIR=./secrets/fb-cookies
# Webshare (or any) proxy list, one per line in this file: host:port:user:pass
FB_PROXY_FILE=./secrets/proxies.txt

# ---- Firebase Cloud Messaging ----
# Path to the service account JSON downloaded from Firebase console.
FCM_SERVICE_ACCOUNT_FILE=./secrets/firebase-service-account.json
# Default topic to publish new-listing notifications to (your app subscribes clients to topics).
FCM_DEFAULT_TOPIC=new-listings

# ---- Storage ----
DB_PATH=./data/seen.db
